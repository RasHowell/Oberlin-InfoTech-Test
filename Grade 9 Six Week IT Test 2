<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grade 9 IT Test — Computer Hardware &amp; Storage</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#0e1117;--surface:#161b27;--card:#1c2333;--border:#2a3347;--accent:#4f8ef7;--accent2:#38d9a9;--text:#e8eaf0;--muted:#7a8399;--correct:#38d9a9;--wrong:#fc5c65;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding-bottom:60px;}
.screen{display:none!important;}
.screen.active{display:block!important;}
#screen-landing{max-width:520px;margin:0 auto;padding:60px 24px;}
.logo{font-family:'Space Mono',monospace;font-size:1.5rem;color:var(--accent);margin-bottom:6px;}
.logo-sub{color:var(--muted);font-size:.85rem;margin-bottom:40px;}
.fg{margin-bottom:20px;}
.fg label{display:block;font-size:.78rem;color:var(--muted);margin-bottom:7px;text-transform:uppercase;letter-spacing:.8px;}
.fg input,.fg select{width:100%;background:var(--card);border:1.5px solid var(--border);border-radius:9px;padding:13px 15px;color:var(--text);font-size:.95rem;font-family:'DM Sans',sans-serif;transition:border-color .2s;}
.fg input:focus,.fg select:focus{outline:none;border-color:var(--accent);}
.fg select option{background:#1c2333;}
.err-msg{color:var(--wrong);font-size:.8rem;margin-top:5px;display:none;}
.btn-start{width:100%;margin-top:6px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border:none;border-radius:10px;padding:15px;font-size:1rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;letter-spacing:.3px;transition:opacity .2s,transform .15s;}
.btn-start:hover{opacity:.9;transform:translateY(-1px);}
.t-link{display:block;text-align:center;margin-top:22px;font-size:.82rem;color:var(--muted);cursor:pointer;text-decoration:underline;}
.t-link:hover{color:var(--accent);}
.t-header{background:linear-gradient(135deg,#0f172a,#1e293b);border-bottom:1px solid var(--border);padding:20px 36px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;}
.t-header h1{font-family:'Space Mono',monospace;font-size:1.25rem;color:var(--accent);}
.meta{display:flex;gap:18px;flex-wrap:wrap;font-size:.78rem;color:var(--muted);margin-top:5px;}
.meta strong{color:var(--text);}
.badge{background:var(--accent);color:#fff;font-size:.68rem;font-weight:700;padding:4px 11px;border-radius:20px;text-transform:uppercase;letter-spacing:.5px;}
.prog-bar-wrap{background:var(--surface);border-bottom:1px solid var(--border);padding:9px 36px;position:sticky;top:0;z-index:20;display:flex;align-items:center;gap:14px;}
.prog-outer{flex:1;height:6px;background:var(--border);border-radius:4px;overflow:hidden;}
.prog-inner{height:100%;width:0%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:4px;transition:width .4s;}
.prog-label{font-size:.75rem;color:var(--muted);white-space:nowrap;}
.q-wrap{max-width:780px;margin:0 auto;padding:32px 24px 0;}
.sec-title{font-family:'Space Mono',monospace;font-size:.67rem;letter-spacing:2px;text-transform:uppercase;color:var(--accent);margin:34px 0 14px;padding-left:11px;border-left:3px solid var(--accent);}
.qcard{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:22px 24px;margin-bottom:14px;}
.qcard:hover{border-color:#3a4a68;}
.qhead{display:flex;gap:11px;align-items:flex-start;margin-bottom:15px;}
.qnum{font-family:'Space Mono',monospace;font-size:.68rem;background:var(--accent);color:#fff;border-radius:6px;padding:3px 8px;flex-shrink:0;margin-top:2px;}
.qtxt{font-size:.93rem;line-height:1.55;}
.opts{display:flex;flex-direction:column;gap:8px;}
.opt{display:flex;align-items:center;gap:10px;background:var(--surface);border:1.5px solid var(--border);border-radius:8px;padding:10px 14px;cursor:pointer;font-size:.88rem;transition:all .18s;}
.opt:hover{border-color:var(--accent);background:#1a2438;}
.opt input{accent-color:var(--accent);width:16px;height:16px;flex-shrink:0;}
.opt.correct{border-color:var(--correct)!important;background:rgba(56,217,169,.09)!important;}
.opt.wrong{border-color:var(--wrong)!important;background:rgba(252,92,101,.09)!important;}
.fb{margin-top:9px;font-size:.8rem;border-radius:6px;padding:7px 12px;display:none;}
.fb.show{display:block;}
.fb.ok{background:rgba(56,217,169,.1);color:var(--correct);}
.fb.bad{background:rgba(252,92,101,.1);color:var(--wrong);}
.btn-submit{display:block;margin:38px auto 0;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border:none;border-radius:10px;padding:14px 50px;font-size:1rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:opacity .2s,transform .15s;}
.btn-submit:hover{opacity:.9;transform:translateY(-1px);}
.btn-submit:disabled{opacity:.45;cursor:not-allowed;transform:none;}
#screen-results{max-width:720px;margin:50px auto 0;padding:0 24px;}
.res-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:38px;text-align:center;}
.res-card h2{font-family:'Space Mono',monospace;font-size:1.2rem;color:var(--accent2);margin-bottom:4px;}
.res-student{color:var(--muted);font-size:.83rem;margin-bottom:4px;}
.score-big{font-family:'Space Mono',monospace;font-size:3.6rem;font-weight:700;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:14px 0;}
.res-msg{color:var(--muted);font-size:.88rem;}
.res-grid{display:flex;justify-content:center;gap:30px;margin-top:22px;flex-wrap:wrap;}
.rstat .v{font-family:'Space Mono',monospace;font-size:1.7rem;font-weight:700;}
.rstat .l{font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:2px;}
.v.c{color:var(--correct);}.v.w{color:var(--wrong);}
.att-note{margin-top:18px;background:rgba(79,142,247,.08);border:1px solid rgba(79,142,247,.2);border-radius:8px;padding:11px 15px;font-size:.8rem;color:var(--accent);}
.btn-retry{margin-top:24px;background:transparent;border:1.5px solid var(--accent);color:var(--accent);border-radius:8px;padding:10px 30px;font-size:.88rem;cursor:pointer;font-family:'DM Sans',sans-serif;}
.btn-retry:hover{background:rgba(79,142,247,.1);}
#screen-teacher{max-width:960px;margin:0 auto;padding:38px 24px;}
.dash-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:26px;flex-wrap:wrap;gap:12px;}
.dash-head h2{font-family:'Space Mono',monospace;font-size:1.15rem;color:var(--accent);}
.btn-back{background:transparent;border:1.5px solid var(--border);color:var(--muted);border-radius:8px;padding:8px 20px;font-size:.83rem;cursor:pointer;font-family:'DM Sans',sans-serif;}
.btn-back:hover{border-color:var(--accent);color:var(--accent);}
.btn-clear{background:transparent;border:1.5px solid var(--wrong);color:var(--wrong);border-radius:8px;padding:8px 20px;font-size:.83rem;cursor:pointer;font-family:'DM Sans',sans-serif;}
.btn-clear:hover{background:rgba(252,92,101,.08);}
.chips{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:26px;}
.chip{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px 20px;flex:1;min-width:100px;text-align:center;}
.chip .cv{font-family:'Space Mono',monospace;font-size:1.5rem;font-weight:700;color:var(--accent);}
.chip .cl{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-top:3px;}
.filters{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;}
.filters input,.filters select{background:var(--card);border:1.5px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--text);font-size:.83rem;font-family:'DM Sans',sans-serif;}
.filters input:focus,.filters select:focus{outline:none;border-color:var(--accent);}
table{width:100%;border-collapse:collapse;font-size:.83rem;}
thead th{background:var(--surface);padding:10px 13px;text-align:left;color:var(--muted);font-size:.7rem;text-transform:uppercase;letter-spacing:.8px;border-bottom:1px solid var(--border);}
tbody tr{border-bottom:1px solid var(--border);}
tbody tr:hover{background:var(--surface);}
tbody td{padding:11px 13px;vertical-align:middle;}
.pill{display:inline-block;padding:3px 10px;border-radius:20px;font-size:.72rem;font-weight:600;}
.pass{background:rgba(56,217,169,.12);color:var(--correct);}
.avg{background:rgba(247,183,49,.12);color:#f7b731;}
.fail{background:rgba(252,92,101,.12);color:var(--wrong);}
.att{display:inline-block;background:rgba(79,142,247,.14);color:var(--accent);border-radius:4px;padding:2px 7px;font-size:.7rem;font-family:'Space Mono',monospace;}
.no-data{text-align:center;padding:50px;color:var(--muted);}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.72);align-items:center;justify-content:center;z-index:999;display:none;}
.modal-bg.open{display:flex;}
.modal-box{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:36px;width:320px;text-align:center;}
.modal-box h3{font-family:'Space Mono',monospace;color:var(--accent);margin-bottom:5px;}
.modal-box p{color:var(--muted);font-size:.8rem;margin-bottom:20px;}
.modal-box input{width:100%;background:var(--surface);border:1.5px solid var(--border);border-radius:8px;padding:11px 14px;color:var(--text);font-size:.95rem;font-family:'DM Sans',sans-serif;text-align:center;letter-spacing:3px;margin-bottom:11px;}
.modal-box input:focus{outline:none;border-color:var(--accent);}
.btn-unlock{width:100%;background:var(--accent);color:#fff;border:none;border-radius:8px;padding:11px;font-size:.95rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;}
.pw-err{color:var(--wrong);font-size:.78rem;margin-top:7px;display:none;}
.btn-cancel{display:block;margin-top:11px;background:none;border:none;color:var(--muted);font-size:.78rem;cursor:pointer;font-family:'DM Sans',sans-serif;}
@media(max-width:600px){.t-header,.prog-bar-wrap{padding-left:16px;padding-right:16px;}.q-wrap{padding:20px 12px 0;}}
</style>
</head>
<body>

<!-- LANDING -->
<div id="screen-landing" class="screen active">
  <div class="logo">Oberlin High School</div>
  <div class="logo-sub">Grade 9 IT &nbsp;&middot;&nbsp; Computer Hardware &amp; Storage &nbsp;&middot;&nbsp; 60 Questions &nbsp;&middot;&nbsp; 60 Marks</div>
  <div id="sync-notice" style="display:none;background:rgba(56,217,169,.1);border:1px solid rgba(56,217,169,.3);border-radius:8px;padding:10px 14px;font-size:.82rem;color:#38d9a9;margin-bottom:20px;"></div>
  <div class="fg">
    <label>Full Name</label>
    <input type="text" id="inp-name" placeholder="e.g. John Smith">
    <div class="err-msg" id="err-name">Please enter your full name.</div>
  </div>
  <div class="fg">
    <label>Class</label>
    <select id="inp-class">
      <option value="">— Select your class —</option>
      <option>9O</option><option>9B</option><option>9E</option>
      <option>9R</option><option>9L</option><option>9I</option>
      <option>9N</option><option>9H</option>
    </select>
    <div class="err-msg" id="err-class">Please select your class.</div>
  </div>
  <button class="btn-start" id="btn-start">Begin Test &rarr;</button>
  <span class="t-link" id="teacher-link">Teacher Results Dashboard</span>
</div>

<!-- TEST -->
<div id="screen-test" class="screen">
  <div class="t-header">
    <div>
      <h1>Oberlin High School &mdash; Grade 9 IT: Computer Hardware &amp; Storage</h1>
      <div class="meta"><span id="hdr-name"></span><span><strong>60 Questions</strong> &nbsp;|&nbsp; <strong>60 Marks</strong></span></div>
    </div>
    <span class="badge">Online Test</span>
  </div>
  <div class="prog-bar-wrap">
    <div class="prog-outer"><div class="prog-inner" id="prog-inner"></div></div>
    <div class="prog-label" id="prog-label">0 / 60 answered</div>
  </div>
  <div class="q-wrap" id="q-wrap">

    <div class="sec-title">Section A &mdash; The CPU &amp; Its Components (Q1&ndash;15)</div>

    <div class="qcard" data-q="1" data-type="mcq" data-answer="C">
      <div class="qhead"><span class="qnum">Q1</span><span class="qtxt">The part of the CPU that performs arithmetic calculations and logic operations is the:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q1" value="A"> Control Unit (CU)</label>
        <label class="opt"><input type="radio" name="q1" value="B"> Random Access Memory (RAM)</label>
        <label class="opt"><input type="radio" name="q1" value="C"> Arithmetic and Logic Unit (ALU)</label>
        <label class="opt"><input type="radio" name="q1" value="D"> Read Only Memory (ROM)</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="2" data-type="mcq" data-answer="B">
      <div class="qhead"><span class="qnum">Q2</span><span class="qtxt">The Control Unit (CU) is responsible for:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q2" value="A"> Performing all mathematical calculations</label>
        <label class="opt"><input type="radio" name="q2" value="B"> Directing and co-ordinating all activities within the CPU</label>
        <label class="opt"><input type="radio" name="q2" value="C"> Storing permanent startup instructions</label>
        <label class="opt"><input type="radio" name="q2" value="D"> Holding data currently being processed</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="3" data-type="mcq" data-answer="A">
      <div class="qhead"><span class="qnum">Q3</span><span class="qtxt">Which two units make up the Central Processing Unit (CPU)?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q3" value="A"> Control Unit (CU) and Arithmetic and Logic Unit (ALU)</label>
        <label class="opt"><input type="radio" name="q3" value="B"> RAM and ROM</label>
        <label class="opt"><input type="radio" name="q3" value="C"> Hard disk and motherboard</label>
        <label class="opt"><input type="radio" name="q3" value="D"> Program Counter and Cache Memory</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="4" data-type="mcq" data-answer="C">
      <div class="qhead"><span class="qnum">Q4</span><span class="qtxt">The Program Counter (PC) in a CPU holds:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q4" value="A"> The result of the most recent arithmetic operation</label>
        <label class="opt"><input type="radio" name="q4" value="B"> The instruction currently being decoded</label>
        <label class="opt"><input type="radio" name="q4" value="C"> The memory address of the next instruction to be executed</label>
        <label class="opt"><input type="radio" name="q4" value="D"> Permanent BIOS startup data</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="5" data-type="mcq" data-answer="D">
      <div class="qhead"><span class="qnum">Q5</span><span class="qtxt">Which of the following is a logic operation performed by the ALU?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q5" value="A"> Addition</label>
        <label class="opt"><input type="radio" name="q5" value="B"> Subtraction</label>
        <label class="opt"><input type="radio" name="q5" value="C"> Multiplication</label>
        <label class="opt"><input type="radio" name="q5" value="D"> AND</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="6" data-type="mcq" data-answer="B">
      <div class="qhead"><span class="qnum">Q6</span><span class="qtxt">Which of the following is NOT a logic operation performed by the ALU?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q6" value="A"> AND</label>
        <label class="opt"><input type="radio" name="q6" value="B"> ADD</label>
        <label class="opt"><input type="radio" name="q6" value="C"> OR</label>
        <label class="opt"><input type="radio" name="q6" value="D"> NOT</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="7" data-type="mcq" data-answer="A">
      <div class="qhead"><span class="qnum">Q7</span><span class="qtxt">A register inside the CPU is best described as:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q7" value="A"> A small, temporary storage location that holds a single instruction or data item</label>
        <label class="opt"><input type="radio" name="q7" value="B"> A large bank of permanent memory on the motherboard</label>
        <label class="opt"><input type="radio" name="q7" value="C"> The bus connecting the CPU to RAM</label>
        <label class="opt"><input type="radio" name="q7" value="D"> A type of secondary storage device</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="8" data-type="mcq" data-answer="C">
      <div class="qhead"><span class="qnum">Q8</span><span class="qtxt">The Instruction Register (IR) in a CPU is used to:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q8" value="A"> Store the address of the next instruction</label>
        <label class="opt"><input type="radio" name="q8" value="B"> Hold the result of calculations temporarily</label>
        <label class="opt"><input type="radio" name="q8" value="C"> Hold the instruction currently being decoded and executed</label>
        <label class="opt"><input type="radio" name="q8" value="D"> Store permanent startup code</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="9" data-type="mcq" data-answer="B">
      <div class="qhead"><span class="qnum">Q9</span><span class="qtxt">The fetch-decode-execute cycle describes:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q9" value="A"> How data is written to and read from secondary storage</label>
        <label class="opt"><input type="radio" name="q9" value="B"> The steps the Control Unit carries out when processing each instruction</label>
        <label class="opt"><input type="radio" name="q9" value="C"> How RAM communicates with ROM</label>
        <label class="opt"><input type="radio" name="q9" value="D"> The process of formatting a hard disk</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="10" data-type="mcq" data-answer="D">
      <div class="qhead"><span class="qnum">Q10</span><span class="qtxt">Cache memory is used in a computer system to:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q10" value="A"> Store programs permanently when the power is off</label>
        <label class="opt"><input type="radio" name="q10" value="B"> Back up important data files automatically</label>
        <label class="opt"><input type="radio" name="q10" value="C"> Replace secondary storage when it is full</label>
        <label class="opt"><input type="radio" name="q10" value="D"> Speed up the CPU by storing frequently used instructions close to the processor</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="11" data-type="mcq" data-answer="A">
      <div class="qhead"><span class="qnum">Q11</span><span class="qtxt">Which of the following is an arithmetic operation performed by the ALU?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q11" value="A"> Division</label>
        <label class="opt"><input type="radio" name="q11" value="B"> AND</label>
        <label class="opt"><input type="radio" name="q11" value="C"> OR</label>
        <label class="opt"><input type="radio" name="q11" value="D"> NOT</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="12" data-type="mcq" data-answer="C">
      <div class="qhead"><span class="qnum">Q12</span><span class="qtxt">The accumulator register in the ALU is used to:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q12" value="A"> Count the number of instructions executed</label>
        <label class="opt"><input type="radio" name="q12" value="B"> Store the address of the next instruction</label>
        <label class="opt"><input type="radio" name="q12" value="C"> Temporarily hold the results of calculations</label>
        <label class="opt"><input type="radio" name="q12" value="D"> Hold the BIOS startup program</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="13" data-type="mcq" data-answer="B">
      <div class="qhead"><span class="qnum">Q13</span><span class="qtxt">Word size in a CPU refers to:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q13" value="A"> The number of words per second a printer can output</label>
        <label class="opt"><input type="radio" name="q13" value="B"> The number of bits the CPU can process in a single operation</label>
        <label class="opt"><input type="radio" name="q13" value="C"> The maximum number of characters in a file name</label>
        <label class="opt"><input type="radio" name="q13" value="D"> The speed of the system clock in MHz</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="14" data-type="mcq" data-answer="D">
      <div class="qhead"><span class="qnum">Q14</span><span class="qtxt">Clock speed of a CPU is measured in:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q14" value="A"> Megabytes (MB)</label>
        <label class="opt"><input type="radio" name="q14" value="B"> Gigabytes (GB)</label>
        <label class="opt"><input type="radio" name="q14" value="C"> Kilobits (Kb)</label>
        <label class="opt"><input type="radio" name="q14" value="D"> Gigahertz (GHz) or Megahertz (MHz)</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="15" data-type="mcq" data-answer="A">
      <div class="qhead"><span class="qnum">Q15</span><span class="qtxt">Which factor does NOT directly affect CPU performance?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q15" value="A"> The brand of the computer monitor</label>
        <label class="opt"><input type="radio" name="q15" value="B"> Clock speed</label>
        <label class="opt"><input type="radio" name="q15" value="C"> Word size</label>
        <label class="opt"><input type="radio" name="q15" value="D"> Cache memory size</label>
      </div><div class="fb"></div>
    </div>

    <div class="sec-title">Section B &mdash; Memory: RAM &amp; ROM (Q16&ndash;25)</div>

    <div class="qcard" data-q="16" data-type="mcq" data-answer="B">
