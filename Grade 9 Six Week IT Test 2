        <label class="opt"><input type="radio" name="q51" value="B"> Scanner</label>
        <label class="opt"><input type="radio" name="q51" value="C"> Monitor</label>
        <label class="opt"><input type="radio" name="q51" value="D"> Speaker</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="52" data-type="mcq" data-answer="D">
      <div class="qhead"><span class="qnum">Q52</span><span class="qtxt">Which of the following is an output device?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q52" value="A"> Keyboard</label>
        <label class="opt"><input type="radio" name="q52" value="B"> Mouse</label>
        <label class="opt"><input type="radio" name="q52" value="C"> Microphone</label>
        <label class="opt"><input type="radio" name="q52" value="D"> Monitor (VDU)</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="53" data-type="mcq" data-answer="A">
      <div class="qhead"><span class="qnum">Q53</span><span class="qtxt">A device that is used for BOTH input and output is:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q53" value="A"> A touchscreen</label>
        <label class="opt"><input type="radio" name="q53" value="B"> A laser printer</label>
        <label class="opt"><input type="radio" name="q53" value="C"> A barcode reader</label>
        <label class="opt"><input type="radio" name="q53" value="D"> A speaker</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="54" data-type="mcq" data-answer="C">
      <div class="qhead"><span class="qnum">Q54</span><span class="qtxt">A hard copy output is one that:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q54" value="A"> Is displayed on a monitor and disappears when power is removed</label>
        <label class="opt"><input type="radio" name="q54" value="B"> Is sent as a digital file via email</label>
        <label class="opt"><input type="radio" name="q54" value="C"> Is printed on paper and has a physical form</label>
        <label class="opt"><input type="radio" name="q54" value="D"> Is stored permanently on a CD-ROM</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="55" data-type="mcq" data-answer="B">
      <div class="qhead"><span class="qnum">Q55</span><span class="qtxt">Which printer type physically strikes a ribbon against paper to form characters?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q55" value="A"> Laser printer</label>
        <label class="opt"><input type="radio" name="q55" value="B"> Dot matrix printer</label>
        <label class="opt"><input type="radio" name="q55" value="C"> Inkjet printer</label>
        <label class="opt"><input type="radio" name="q55" value="D"> Thermal printer</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="56" data-type="mcq" data-answer="D">
      <div class="qhead"><span class="qnum">Q56</span><span class="qtxt">A laser printer produces output by:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q56" value="A"> Spraying tiny ink droplets directly onto paper</label>
        <label class="opt"><input type="radio" name="q56" value="B"> Striking a ribbon to imprint characters onto the page</label>
        <label class="opt"><input type="radio" name="q56" value="C"> Burning dots onto heat-sensitive paper</label>
        <label class="opt"><input type="radio" name="q56" value="D"> Using a laser beam to attract toner onto paper, then fusing it with heat</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="57" data-type="mcq" data-answer="A">
      <div class="qhead"><span class="qnum">Q57</span><span class="qtxt">Which input device is most commonly used to read price information at supermarket checkouts?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q57" value="A"> Barcode reader (scanner)</label>
        <label class="opt"><input type="radio" name="q57" value="B"> OMR (Optical Mark Reader)</label>
        <label class="opt"><input type="radio" name="q57" value="C"> MICR reader</label>
        <label class="opt"><input type="radio" name="q57" value="D"> Joystick</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="58" data-type="mcq" data-answer="C">
      <div class="qhead"><span class="qnum">Q58</span><span class="qtxt">MICR (Magnetic Ink Character Recognition) is used mainly for:</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q58" value="A"> Reading multiple-choice answer sheets</label>
        <label class="opt"><input type="radio" name="q58" value="B"> Identifying individuals by fingerprint scanning</label>
        <label class="opt"><input type="radio" name="q58" value="C"> Reading bank cheques encoded with magnetic ink</label>
        <label class="opt"><input type="radio" name="q58" value="D"> Scanning items at supermarket checkouts</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="59" data-type="mcq" data-answer="B">
      <div class="qhead"><span class="qnum">Q59</span><span class="qtxt">Which output device is used in CAD to draw large, high-quality diagrams and maps on wide paper?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q59" value="A"> Dot matrix printer</label>
        <label class="opt"><input type="radio" name="q59" value="B"> Plotter</label>
        <label class="opt"><input type="radio" name="q59" value="C"> Laser printer</label>
        <label class="opt"><input type="radio" name="q59" value="D"> Monitor</label>
      </div><div class="fb"></div>
    </div>

    <div class="qcard" data-q="60" data-type="mcq" data-answer="D">
      <div class="qhead"><span class="qnum">Q60</span><span class="qtxt">Which of the following BEST describes secondary storage?</span></div>
      <div class="opts">
        <label class="opt"><input type="radio" name="q60" value="A"> Memory that is volatile and loses data when power is removed</label>
        <label class="opt"><input type="radio" name="q60" value="B"> The memory used by the CPU to run programs currently open</label>
        <label class="opt"><input type="radio" name="q60" value="C"> Read-only memory that holds startup instructions permanently</label>
        <label class="opt"><input type="radio" name="q60" value="D"> Permanent storage outside the CPU that retains data without power</label>
      </div><div class="fb"></div>
    </div>

    <button class="btn-submit" id="btn-submit">Submit Test</button>
  </div>
</div>

<!-- RESULTS -->
<div id="screen-results" class="screen">
  <div id="res-inner" style="max-width:720px;margin:50px auto 0;padding:0 24px;">
    <div class="res-card">
      <h2>Test Complete!</h2>
      <div class="res-student" id="res-student"></div>
      <div class="score-big" id="res-pct">&mdash;</div>
      <div class="res-msg" id="res-msg"></div>
      <div class="res-grid">
        <div class="rstat"><div class="v c" id="res-correct">&mdash;</div><div class="l">Correct</div></div>
        <div class="rstat"><div class="v w" id="res-wrong">&mdash;</div><div class="l">Incorrect</div></div>
        <div class="rstat"><div class="v" style="color:var(--accent)">60</div><div class="l">Total</div></div>
      </div>
      <div class="att-note" id="att-note" style="display:none;"></div>
      <div id="retry-wrap"></div>
    </div>
  </div>
</div>

<!-- TEACHER DASHBOARD -->
<div id="screen-teacher" class="screen">
  <div class="dash-head">
    <h2>&#128202; Teacher Results Dashboard</h2>
    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <button class="btn-clear" onclick="clearAll()">&#128465; Clear All Results</button>
      <button class="btn-back" onclick="goToLanding()">&larr; Back</button>
    </div>
  </div>
  <div class="chips" id="dash-chips"></div>
  <div class="filters">
    <input type="text" id="f-name" placeholder="&#128269; Search name&hellip;" oninput="renderDash()">
    <select id="f-class" onchange="renderDash()">
      <option value="">All Classes</option>
      <option>9O</option><option>9B</option><option>9E</option>
      <option>9R</option><option>9L</option><option>9I</option>
      <option>9N</option><option>9H</option>
    </select>
    <select id="f-sort" onchange="renderDash()">
      <option value="newest">Newest first</option>
      <option value="oldest">Oldest first</option>
      <option value="hi">Highest score</option>
      <option value="lo">Lowest score</option>
      <option value="name">Name A&ndash;Z</option>
    </select>
  </div>
  <table>
    <thead>
      <tr><th>#</th><th>Name</th><th>Class</th><th>Score</th><th>%</th><th>Attempt</th><th>Date &amp; Time</th><th>Result</th></tr>
    </thead>
    <tbody id="dash-tbody"></tbody>
  </table>
</div>

<!-- PASSWORD MODAL -->
<div class="modal-bg" id="pw-modal">
  <div class="modal-box">
    <h3>Teacher Access</h3>
    <p>Enter the teacher password to view student results.</p>
    <input type="password" id="pw-input" placeholder="Password" onkeydown="if(event.key==='Enter')checkPw()">
    <div class="pw-err" id="pw-err">Incorrect password. Try again.</div>
    <button class="btn-unlock" onclick="checkPw()">Unlock Dashboard</button>
    <button class="btn-cancel" onclick="closePw()">Cancel</button>
  </div>
</div>

<script>
const TOTAL = 60;

window.addEventListener('load', async () => {
  const local = JSON.parse(localStorage.getItem('it_gr9_results') || '[]');
  if (local.length > 0) {
    const notice = document.getElementById('sync-notice');
    if (notice) {
      notice.style.display = 'block';
      notice.textContent = 'Syncing ' + local.length + ' saved result(s) to server...';
    }
    await syncLocalToSheets();
    if (notice) {
      notice.textContent = 'Local results synced successfully!';
      setTimeout(() => { notice.style.display = 'none'; }, 4000);
    }
  }
});

const PW = 'ras4real';
let student = {name:'', cls:''};
let answered = new Set();

function show(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
  window.scrollTo(0, 0);
}

function goToLanding() { show('landing'); }

document.getElementById('btn-start').addEventListener('click', async function() {
  const name = document.getElementById('inp-name').value.trim();
  const cls  = document.getElementById('inp-class').value;
  let ok = true;
  document.getElementById('err-name').style.display = name ? 'none' : 'block'; if (!name) ok = false;
  document.getElementById('err-class').style.display = cls  ? 'none' : 'block'; if (!cls)  ok = false;
  if (!ok) return;

  const btn = document.getElementById('btn-start');
  btn.textContent = 'Checking... please wait';
  btn.disabled = true;

  const prevAttempts = await getPrevAttempts(name, cls);

  if (prevAttempts >= 2) {
    const errEl = document.getElementById('err-name');
    errEl.style.color = 'var(--wrong)';
    errEl.textContent = '\u26d4 ' + name + ' has already used both attempts. No further attempts are allowed.';
    errEl.style.display = 'block';
    btn.textContent = 'Begin Test \u2192';
    btn.disabled = false;
    return;
  }

  if (prevAttempts === 1) {
    const errEl = document.getElementById('err-name');
    errEl.style.color = '#f7b731';
    errEl.textContent = '\u26a0\ufe0f This is your FINAL attempt. You cannot retake the test after submitting.';
    errEl.style.display = 'block';
  }

  student = {name, cls};
  document.getElementById('hdr-name').innerHTML = '<strong>' + name + '</strong> &nbsp;\u00b7&nbsp; Class <strong>' + cls + '</strong>';
  btn.textContent = 'Begin Test \u2192';
  btn.disabled = false;
  show('test');
  answered = new Set();
  updateProg();
});

function updateProg() {
  const pct = (answered.size / TOTAL) * 100;
  document.getElementById('prog-inner').style.width = pct + '%';
  document.getElementById('prog-label').textContent = answered.size + ' / ' + TOTAL + ' answered';
}

document.querySelectorAll('.opt input[type=radio]').forEach(r => {
  r.addEventListener('change', () => { answered.add(r.closest('.qcard').dataset.q); updateProg(); });
});

document.getElementById('btn-submit').addEventListener('click', async function() {
  let correct = 0;
  document.querySelectorAll('.qcard').forEach(card => {
    const type = card.dataset.type;
    const ans  = card.dataset.answer;
    const fb   = card.querySelector('.fb');
    let ok = false;

    if (type === 'mcq') {
      const sel = card.querySelector('input[type=radio]:checked');
      const chosen = sel ? sel.value : null;
      card.querySelectorAll('.opt').forEach(lbl => {
        const v = lbl.querySelector('input').value;
        if (v === ans) lbl.classList.add('correct');
        else if (v === chosen && chosen !== ans) lbl.classList.add('wrong');
      });
      ok = chosen === ans;
    }

    if (ok) { correct++; fb.textContent = '\u2713 Correct!'; fb.className = 'fb show ok'; }
    else { fb.textContent = '\u2717 Incorrect \u2014 correct answer highlighted in green.'; fb.className = 'fb show bad'; }
    card.querySelectorAll('input,button').forEach(el => el.disabled = true);
  });

  const prevAttempts2 = await getPrevAttempts(student.name, student.cls);
  const attemptNo = prevAttempts2 + 1;
  const pct = Math.round((correct / TOTAL) * 100);
  const record = { name: student.name, cls: student.cls, correct, total: TOTAL, pct, attempt: attemptNo, ts: new Date().toISOString() };
  await saveData(record);

  document.getElementById('res-student').textContent = student.name + '  \u00b7  Class ' + student.cls;
  document.getElementById('res-pct').textContent = pct + '%';
  document.getElementById('res-msg').textContent = correct + ' out of ' + TOTAL + ' correct.  ' +
    (pct >= 70 ? '\ud83c\udf89 Well done!' : pct >= 50 ? 'Good effort \u2014 keep studying!' : 'Review your notes and try again!');
  document.getElementById('res-correct').textContent = correct;
  document.getElementById('res-wrong').textContent = TOTAL - correct;
  const note = document.getElementById('att-note');
  const retryWrap = document.getElementById('retry-wrap');
  if (attemptNo === 1) {
    note.textContent = '\u26a0\ufe0f This was attempt 1 of 2. You have one attempt remaining.';
    note.style.display = 'block';
    retryWrap.innerHTML = '<button class="btn-retry" onclick="location.reload()">\u21ba Try Again (Final Attempt)</button>';
  } else {
    note.textContent = '\u26d4 You have used both attempts. This result is final.';
    note.style.display = 'block';
    retryWrap.innerHTML = '<p style="margin-top:18px;font-size:.82rem;color:var(--muted)">No more attempts allowed.</p>';
  }

  this.disabled = true;
  show('results');
});

document.getElementById('teacher-link').addEventListener('click', function() {
  document.getElementById('pw-modal').classList.add('open');
  document.getElementById('pw-input').value = '';
  document.getElementById('pw-err').style.display = 'none';
  setTimeout(() => document.getElementById('pw-input').focus(), 80);
});

function closePw() { document.getElementById('pw-modal').classList.remove('open'); }

function checkPw() {
  if (document.getElementById('pw-input').value === PW) {
    closePw(); show('teacher'); renderDash();
  } else {
    document.getElementById('pw-err').style.display = 'block';
    document.getElementById('pw-input').value = '';
    document.getElementById('pw-input').focus();
  }
}

async function renderDash() {
  document.getElementById('dash-chips').innerHTML = '<div style="color:var(--muted);font-size:.85rem;padding:10px;">\u23f3 Loading results from server...</div>';
  const all = await loadData();
  const avg = all.length ? Math.round(all.reduce((s,r) => s+r.pct, 0) / all.length) : 0;
  const best = all.length ? Math.max(...all.map(r=>r.pct)) : 0;
  const passes = all.filter(r=>r.pct>=50).length;
  document.getElementById('dash-chips').innerHTML =
    chip(all.length,'Total Submissions') + chip(avg+'%','Class Average') +
    chip(best+'%','Highest Score') + chip(passes,'Passed (\u226550%)');
  renderTable(all);
}

function chip(v,l){ return '<div class="chip"><div class="cv">'+v+'</div><div class="cl">'+l+'</div></div>'; }

function renderTable(all) {
  all = all || [];
  const search = (document.getElementById('f-name').value||'').toLowerCase();
  const cls    = document.getElementById('f-class').value||'';
  const sort   = document.getElementById('f-sort').value||'newest';
  let rows = all.filter(r => r.name.toLowerCase().includes(search) && (!cls || r.cls===cls));
  rows.sort((a,b) => {
    if(sort==='newest') return new Date(b.ts)-new Date(a.ts);
    if(sort==='oldest') return new Date(a.ts)-new Date(b.ts);
    if(sort==='hi')     return b.pct-a.pct;
    if(sort==='lo')     return a.pct-b.pct;
    if(sort==='name')   return a.name.localeCompare(b.name);
    return 0;
  });
  const tbody = document.getElementById('dash-tbody');
  if (!rows.length) { tbody.innerHTML = '<tr><td colspan="8" class="no-data">No results yet.</td></tr>'; return; }
  tbody.innerHTML = rows.map((r,i) => {
    const d  = new Date(r.ts);
    const dt = d.toLocaleDateString('en-ZA') + ' ' + d.toLocaleTimeString('en-ZA',{hour:'2-digit',minute:'2-digit'});
    const pill = r.pct>=70 ? '<span class="pill pass">Pass</span>' : r.pct>=50 ? '<span class="pill avg">Average</span>' : '<span class="pill fail">Below avg</span>';
    return '<tr><td style="color:var(--muted)">'+(i+1)+'</td><td><strong>'+r.name+'</strong></td><td>'+r.cls+'</td><td>'+r.correct+'/'+r.total+'</td><td><strong>'+r.pct+'%</strong></td><td><span class="att">#'+r.attempt+'</span></td><td style="color:var(--muted);font-size:.78rem">'+dt+'</td><td>'+pill+'</td></tr>';
  }).join('');
}

async function clearAll() {
  if (confirm('Delete ALL student results from Google Sheets? This cannot be undone.')) {
    try { await fetch(GAS_URL + '?action=clear'); renderDash(); }
    catch(e) { alert('Could not clear results. Try again.'); }
  }
}

async function syncLocalToSheets() {
  const localKey = 'it_gr9_results';
  const syncedKey = 'it_gr9_synced';
  let local = [];
  try { local = JSON.parse(localStorage.getItem(localKey) || '[]'); } catch(e) { return; }
  if (!local.length) return;
  const alreadySynced = JSON.parse(localStorage.getItem(syncedKey) || '[]');
  const toSync = local.filter(r => !alreadySynced.includes(r.name+'|'+r.cls+'|'+r.ts));
  if (!toSync.length) return;
  const newlySynced = [...alreadySynced];
  for (const r of toSync) {
    try {
      await fetch(GAS_URL, { method:'POST', mode:'no-cors', headers:{'Content-Type':'application/json'}, body:JSON.stringify(r) });
      newlySynced.push(r.name+'|'+r.cls+'|'+r.ts);
    } catch(e) { console.warn('Failed to sync:', r.name); }
  }
  localStorage.setItem(syncedKey, JSON.stringify(newlySynced));
}

const GAS_URL = 'https://script.google.com/macros/s/AKfycbz74Qn-HvP4KY4OueggZgxetkZakiwViJ-kOg9kRICxxq6ESZEJAMRYU-XBkN3D_iJK1w/exec';

async function saveData(record) {
  try {
    await fetch(GAS_URL, { method:'POST', mode:'no-cors', headers:{'Content-Type':'application/json'}, body:JSON.stringify(record) });
  } catch(e) { console.error('Save error', e); }
}

async function loadData() {
  try {
    const res = await fetch(GAS_URL + '?action=get');
    const rows = await res.json();
    return rows.slice(1).map(r => ({
      name:r[0], cls:r[1], correct:Number(r[2]),
      total:Number(r[3]), pct:Number(r[4]),
      attempt:Number(r[5]), ts:r[6]
    }));
  } catch(e) { console.error('Load error', e); return []; }
}

async function getPrevAttempts(name, cls) {
  const all = await loadData();
  return all.filter(r => r.name.toLowerCase() === name.toLowerCase() && r.cls === cls).length;
}
</script>
